{{#section}}
  <p style="margin:0;">Hi {{volunteerName}}, you're booked onto the next <strong>{{groupName}}</strong>.</p>
{{/section}}

{{#section style="sand"}}
  <strong>Date:</strong> {{formattedDateLong}}<br>
  <strong>Time:</strong> 9:30 to 12:30 (about 3 hours)<br>
  <strong>Location:</strong> Forest of Dean Cycle Centre
{{/section}}

{{#section}}
  {{#if description}}
  <p style="margin:0 0 16px;">{{{description}}}</p>
  {{/if}}

  <p style="margin:0 0 16px;">Please bring sturdy boots, clothes you don't mind getting muddy, and water. Gloves are useful if you have them. We'll provide tools and hi-viz.</p>

  <p style="margin:0 0 16px;"><a href="{{sessionUrl}}" style="color:#41903D;">View session page</a></p>

  {{#if isRegular}}
  <p style="margin:0 0 16px;">You're a {{groupName}} regular, so we sign you up automatically.</p>
  {{/if}}

  <p style="margin:0 0 16px;">Can't make it? Please let us know and <a href="{{loginUrl}}" style="color:#41903D;">log in to cancel your place</a>.</p>

  {{#if myChildNames}}
  <p style="margin:0;">You're signed up as the accompanying adult for {{myChildNames}}.</p>
  {{/if}}
{{/section}}
