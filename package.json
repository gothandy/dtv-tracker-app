{
  "name": "volunteer-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "start": "node app.js",
    "dev": "cross-env NODE_ENV=development nodemon app.js",
    "test": "echo \"No automated tests (run npm run test:live for integration tests)\"",
    "test:live": "node test/run-tests.js",
    "frontend:build": "cd frontend && npm run build"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules/",
      "docs/",
      ".env"
    ],
    "watch": [
      "app.js",
      "dist/",
      "templates/"
    ],
    "ext": "js,json,ts,hbs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@azure/msal-node": "^5.0.3",
    "@types/cookie-parser": "^1.4.10",
    "axios": "^1.13.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.4",
    "exifreader": "^4.36.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.9",
    "luxon": "^3.7.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.2",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
