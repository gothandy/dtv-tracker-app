{
  "name": "volunteer-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "node -e \"const {execSync}=require('child_process'),fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});try{const c=execSync('git rev-parse HEAD').toString().trim();fs.writeFileSync('public/build.json',JSON.stringify({built:new Date().toISOString(),commit:c}))}catch(e){}\"",
    "build": "tsc",
    "start": "node app.js",
    "dev": "nodemon app.js",
    "dev:members": "dotenv -e .env.members -- nodemon app.js",
    "dev:tracker": "dotenv -e .env.tracker -- nodemon app.js",
    "test": "echo \"No automated tests (run npm run test:live for integration tests)\"",
    "test:live": "node test/run-tests.js"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules/",
      "public/",
      "docs/",
      ".env"
    ],
    "watch": [
      "app.js",
      "dist/"
    ],
    "ext": "js,json,ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@azure/msal-node": "^5.0.3",
    "axios": "^1.13.4",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.4",
    "exifreader": "^4.36.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "luxon": "^3.7.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-magic-login": "^1.2.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/luxon": "^3.7.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "dotenv-cli": "^11.0.0",
    "jimp": "^1.6.0",
    "nodemon": "^3.1.11",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
